# --- Paiement Stripe ---------------------------------------------------------
# Clé secrète TEST (dashboard.stripe.com → Développeurs → Clés API)
STRIPE_SECRET_KEY=sk_test_xxx
# Secret du webhook (Stripe CLI : `stripe listen --forward-to localhost:3000/api/stripe/webhook`)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Supabase (base des commandes) ------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Clé service_role (SECRET, côté serveur uniquement) — Project Settings → API
SUPABASE_SERVICE_ROLE_KEY=xxx

# --- Emails transactionnels (Resend, resend.com) -----------------------------
# Clé API (Resend → API Keys). Sans elle, aucun email n'est envoyé (no-op).
RESEND_API_KEY=re_xxx
# Expéditeur : le domaine doit être vérifié dans Resend (DNS SPF + DKIM)
EMAIL_FROM="Deux comme nous <commandes@gemellite.com>"
# Adresse interne prévenue à chaque commande payée (Simon)
EMAIL_NOTIF=simon@exemple.com

# --- Génération des variantes sur-mesure (OpenAI) ----------------------------
# Sans clé, le site propose un repli (« propositions par e-mail sous 24 h »).
OPENAI_API_KEY=sk-xxx
# Qualité gpt-image-1 des variantes : low | medium | high (défaut medium)
GEN_QUALITE=medium

# --- Divers ------------------------------------------------------------------
# Prix du livre en centimes (44,90 € = 4490)
PRIX_CENTIMES=4490
# Frais de livraison en centimes (4,99 € = 499)
LIVRAISON_CENTIMES=499
